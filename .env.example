# ---------------------------------------------------------------------------
# LiveKit Cloud project credentials (free "Build" plan is enough for the demo).
# Create a project at https://cloud.livekit.io -> Settings -> Keys.
# These three values also authenticate LiveKit Inference (STT/LLM/TTS) —
# no separate provider API keys are needed on the default configuration.
# ---------------------------------------------------------------------------
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ---------------------------------------------------------------------------
# LLM provider switch.
#   inference    -> LiveKit Inference (default; runs on the free plan credit)
#   anthropic    -> direct Anthropic API (set ANTHROPIC_API_KEY, e.g. model claude-haiku-4-5)
#   self_hosted  -> on-prem OpenAI-compatible server (vLLM/TGI/SGLang/Ollama) - no
#                   customer voice/account data leaves the bank's network. See
#                   docs/PITCH.md for model/hardware recommendations.
# ---------------------------------------------------------------------------
LLM_PROVIDER=inference
LLM_MODEL=openai/gpt-4.1-mini
ANTHROPIC_API_KEY=

# self_hosted only - point at your OpenAI-compatible inference server, e.g.:
#   vllm serve mistralai/Mistral-Small-3.2-24B-Instruct-2506 --port 8001
#   LLM_MODEL=mistralai/Mistral-Small-3.2-24B-Instruct-2506
SELF_HOSTED_LLM_BASE_URL=http://localhost:8001/v1
# Only needed if something in front of your server enforces auth.
SELF_HOSTED_LLM_API_KEY=

# STT / TTS via LiveKit Inference (swap models freely; see docs.livekit.io/agents/models)
STT_MODEL=deepgram/nova-3
TTS_MODEL=cartesia/sonic-3
# Optional named voice for the TTS model; leave empty for the provider default.
TTS_VOICE=

# Step-up verification (one-time codes to the simulated banking app).
# STEP_UP_ENABLED=false demos the original single-tier flow (step-up tools
# removed from the agent entirely). STEP_UP_MODE places the gate:
#   actions -> reads need tier-1 only; card blocks/disputes need the code
#              (risk-proportionate; the production-standard policy)
#   always  -> code required right after identity verification, before ANY
#              account data (maximal gate; friction on every call)
# Production replaces this static switch with risk-based gating (fraud
# signals). Restart the worker after changing either value.
STEP_UP_ENABLED=true
STEP_UP_MODE=actions

# Idle-caller watchdog: after IDLE_PROMPT_AFTER_SECONDS of caller silence the
# agent asks "are you still there?"; after IDLE_HANGUP_AFTER_SECONDS more it
# says goodbye and hangs up. SET IDLE_TIMEOUT_ENABLED=false WHEN PITCHING
# WITH A MUTED MIC - otherwise the agent will hang up on your demo call.
IDLE_TIMEOUT_ENABLED=true
IDLE_PROMPT_AFTER_SECONDS=20
IDLE_HANGUP_AFTER_SECONDS=15

# Explicit-dispatch agent name. The worker registers under this name; the
# browser token endpoint and the SIP dispatch rule (scripts/setup_sip.py)
# both request it. One value shared by backend + agent. Registration happens
# once at worker startup - restart `make dev` after changing this.
AGENT_NAME=meridian-bank-agent

# Mock core-banking backend, as seen from the agent process.
BACKEND_BASE_URL=http://localhost:8000

# console (pretty, for local dev) | json (structured, for containers)
LOG_FORMAT=console

# ---------------------------------------------------------------------------
# Frontend (Vite reads its own file: frontend/.env.local)
#   VITE_BACKEND_URL=http://localhost:8000
# ---------------------------------------------------------------------------
