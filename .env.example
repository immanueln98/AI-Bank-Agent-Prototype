# ---------------------------------------------------------------------------
# LiveKit Cloud project credentials (free "Build" plan is enough for the demo).
# Create a project at https://cloud.livekit.io -> Settings -> Keys.
# These three values also authenticate LiveKit Inference (STT/LLM/TTS) —
# no separate provider API keys are needed on the default configuration.
# ---------------------------------------------------------------------------
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ---------------------------------------------------------------------------
# LLM provider switch.
#   inference  -> LiveKit Inference (default; runs on the free plan credit)
#   anthropic  -> direct Anthropic API (set ANTHROPIC_API_KEY, e.g. model claude-haiku-4-5)
# ---------------------------------------------------------------------------
LLM_PROVIDER=inference
LLM_MODEL=openai/gpt-4.1-mini
ANTHROPIC_API_KEY=

# STT / TTS via LiveKit Inference (swap models freely; see docs.livekit.io/agents/models)
STT_MODEL=deepgram/nova-3
TTS_MODEL=cartesia/sonic-3
# Optional named voice for the TTS model; leave empty for the provider default.
TTS_VOICE=

# Explicit-dispatch agent name. The worker registers under this name; the
# browser token endpoint and the SIP dispatch rule (scripts/setup_sip.py)
# both request it. One value shared by backend + agent.
AGENT_NAME=meridian-bank-agent

# Mock core-banking backend, as seen from the agent process.
BACKEND_BASE_URL=http://localhost:8000

# console (pretty, for local dev) | json (structured, for containers)
LOG_FORMAT=console

# ---------------------------------------------------------------------------
# Frontend (Vite reads its own file: frontend/.env.local)
#   VITE_BACKEND_URL=http://localhost:8000
# ---------------------------------------------------------------------------
